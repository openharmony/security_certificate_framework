### 2.2 Inner C接口

#### 2.2.1 核心数据结构

```c
// 验证参数结构体
typedef struct {
    HcfX509CertificateArray untrustedCerts;
    HcfX509CertificateArray trustedCerts;
    bool trustSystemCa;
    bool partialChain;
    bool allowDownloadIntermediateCa;  // 是否允许下载中间证书
    bool validateDate;
    char *date;
    HcfInt32Array ignoreErrs;
    HcfStringArray hostnames;
    HcfStringArray emailAddresses;
    HcfInt32Array keyUsage;
    CfBlob userId;
    HcfX509CertRevokedParams *revokedParams;
} HcfX509CertValidatorParams;

// 验证结果结构体
typedef struct {
    HcfX509CertificateArray certs;
    const char *errorMsg;
} HcfVerifyCertResult;

// 证书链验证器接口
struct HcfCertChainValidator {
    struct CfObjectBase base;

    // 验证证书链（原有接口）
    CfResult (*validate)(HcfCertChainValidator *self, const HcfCertChainData *certChainData);

    // 获取算法名称
    const char *(*getAlgorithm)(HcfCertChainValidator *self);

    // 验证单个X509证书（新增接口）
    CfResult (*validateX509Cert)(HcfCertChainValidator *self, HcfX509Certificate *cert,
        const HcfX509CertValidatorParams *params, HcfVerifyCertResult *result);
};
```

#### 2.2.2 创建函数

```c
/**
 * @brief 创建证书链验证器实例
 * @param algorithm 算法名称，目前支持 "PKIX"
 * @param pathValidator 输出参数，返回验证器实例
 * @return CfResult 操作结果
 */
CfResult HcfCertChainValidatorCreate(const char *algorithm, HcfCertChainValidator **pathValidator);
```

#### 2.2.3 错误码定义

```c
typedef enum {
    CF_SUCCESS = 0,
    CF_INVALID_PARAMS = -10001,
    CF_ERR_MALLOC = -10002,
    CF_ERR_NAPI = -10003,
    CF_ERR_PARAMETER_CHECK = -10004,
    CF_ERR_CRYPTO_OPERATION = -20001,
    CF_ERR_CERT_SIGNATURE_FAILURE = -20002,
    CF_ERR_CERT_NOT_YET_VALID = -20003,
    CF_ERR_CERT_HAS_EXPIRED = -20004,
    CF_ERR_UNABLE_TO_GET_ISSUER_CERT_LOCALLY = -20005,
    CF_ERR_KEYUSAGE_NO_CERTSIGN = -20006,
    CF_ERR_KEYUSAGE_NO_DIGITAL_SIGNATURE = -20007,
    CF_ERR_CERT_UNTRUSTED = -20009,
    CF_ERR_CERT_REVOKED = -20010,
    CF_ERR_CERT_UNKNOWN_CRITICAL_EXTENSION = -20011,
    CF_ERR_CERT_HOSTNAME_MISMATCH = -20012,
    CF_ERR_CERT_EMAIL_ADDRESS_MISMATCH = -20013,
    CF_ERR_CERT_KEYUSAGE_MISMATCH = -20014,
    CF_ERR_NETWORK_TIMEOUT = -30025,
    // ... 其他错误码
} CfResult;
```

