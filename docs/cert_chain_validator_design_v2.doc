## 2 实现方案

### 2.1 JS接口

#### 2.1.1 接口定义

**CertChainValidator 类**

```typescript
interface CertChainValidator {
  // 原有接口：验证证书链
  validate(certChainData: CertChainData, callback: AsyncCallback<void>): void;
  validate(certChainData: CertChainData): Promise<void>;

  // 新增接口：带参数验证单个证书
  validate(cert: X509Cert, params: X509CertValidatorParams, callback: AsyncCallback<VerifyCertResult>): void;
  validate(cert: X509Cert, params: X509CertValidatorParams): Promise<VerifyCertResult>;

  // 获取算法名称
  readonly algorithm: string;
}
```

**创建验证器**

```typescript
function createCertChainValidator(algorithm: string): CertChainValidator;
```

#### 2.1.2 参数结构定义

**X509CertValidatorParams 参数结构**

```typescript
interface X509CertValidatorParams {
  // 信任证书列表（必填，或设置trustSystemCa为true）
  trustedCerts?: Array<X509Cert>;
  // 非信任证书列表（用于提供中间证书）
  untrustedCerts?: Array<X509Cert>;
  // 是否信任系统CA证书
  trustSystemCa?: boolean;
  // 是否允许部分链验证
  partialChain?: boolean;
  // 是否允许自动下载中间证书（新增核心特性）
  allowDownloadIntermediateCa?: boolean;
  // 是否验证日期
  validateDate?: boolean;
  // 验证日期（字符串格式，如"20231231235959Z"）
  date?: string;
  // 忽略的错误码列表
  ignoreErrs?: Array<number>;
  // 主机名列表（用于主机名验证）
  hostnames?: Array<string>;
  // 邮箱地址列表（用于邮箱验证）
  emailAddresses?: Array<string>;
  // 密钥用途列表
  keyUsage?: Array<KeyUsageType>;
  // 用户ID
  userId?: Uint8Array;
  // 吊销检查参数
  revokedParams?: X509CertRevokedParams;
}
```

**X509CertRevokedParams 吊销检查参数**

```typescript
interface X509CertRevokedParams {
  // 吊销检查标志
  revocationFlags?: Array<number>;  // 0:PREFER_OCSP, 1:CRL_CHECK, 2:OCSP_CHECK, 3:CHECK_ALL_CERT
  // CRL列表
  crls?: Array<X509Crl>;
  // 是否允许下载CRL
  allowDownloadCrl?: boolean;
  // 是否允许在线OCSP检查
  allowOcspCheckOnline?: boolean;
  // OCSP响应数据
  ocspResponses?: Array<Uint8Array>;
  // OCSP摘要算法
  ocspDigest?: Array<number>;  // 0:SHA1, 1:SHA224, 2:SHA256, 3:SHA384, 4:SHA512
}
```

**VerifyCertResult 结果结构**

```typescript
interface VerifyCertResult {
  // 验证后的证书链
  certChain?: Array<X509Cert>;
  // 错误信息
  errorMsg?: string;
}
```

**KeyUsageType 枚举**

```typescript
enum KeyUsageType {
  KEYUSAGE_DIGITAL_SIGNATURE = 0,
  KEYUSAGE_NON_REPUDIATION = 1,
  KEYUSAGE_KEY_ENCIPHERMENT = 2,
  KEYUSAGE_DATA_ENCIPHERMENT = 3,
  KEYUSAGE_KEY_AGREEMENT = 4,
  KEYUSAGE_KEY_CERT_SIGN = 5,
  KEYUSAGE_CRL_SIGN = 6,
  KEYUSAGE_ENCIPHER_ONLY = 7,
  KEYUSAGE_DECIPHER_ONLY = 8
}
```

#### 2.1.3 使用示例

**示例1：基本使用**

```javascript
import cert from '@ohos.security.cert';

// 创建证书链验证器
let validator = cert.createCertChainValidator("PKIX");

// 准备验证参数
let params = {
  trustedCerts: [rootCert],           // 信任的根证书
  allowDownloadIntermediateCa: true,  // 启用自动下载中间证书
  validateDate: true                  // 验证日期
};

// 验证证书
try {
  let result = await validator.validate(leafCert, params);
  console.log("Verification succeeded");
  console.log("Certificate chain length:", result.certChain.length);
} catch (err) {
  console.log("Verification failed:", err.message);
}
```

**示例2：完整参数**

```javascript
let params = {
  trustedCerts: [rootCert],
  untrustedCerts: [intermediateCert1, intermediateCert2],
  trustSystemCa: false,
  partialChain: false,
  allowDownloadIntermediateCa: true,
  validateDate: true,
  date: "20241231235959Z",
  hostnames: ["example.com", "www.example.com"],
  emailAddresses: ["admin@example.com"],
  keyUsage: [cert.KeyUsageType.KEYUSAGE_DIGITAL_SIGNATURE],
  revokedParams: {
    revocationFlags: [0, 1],  // PREFER_OCSP, CRL_CHECK
    allowDownloadCrl: true,
    allowOcspCheckOnline: true
  }
};

let result = await validator.validate(leafCert, params);
```

#### 2.1.4 错误码定义

| 错误码 | 常量名 | 说明 |
|--------|--------|------|
| 0 | JS_SUCCESS | 成功 |
| 401 | JS_ERR_CERT_INVALID_PARAMS | 参数无效 |
| 801 | JS_ERR_CERT_NOT_SUPPORT | 不支持的功能 |
| 19020001 | JS_ERR_CERT_OUT_OF_MEMORY | 内存不足 |
| 19020002 | JS_ERR_CERT_RUNTIME_ERROR | 运行时错误 |
| 19020003 | JS_ERR_CERT_PARAMETER_CHECK | 参数校验失败 |
| 19030001 | JS_ERR_CERT_CRYPTO_OPERATION | 密码学操作失败 |
| 19030002 | JS_ERR_CERT_SIGNATURE_FAILURE | 证书签名验证失败 |
| 19030003 | JS_ERR_CERT_NOT_YET_VALID | 证书尚未生效 |
| 19030004 | JS_ERR_CERT_HAS_EXPIRED | 证书已过期 |
| 19030005 | JS_ERR_UNABLE_TO_GET_ISSUER_CERT_LOCALLY | 无法获取本地颁发者证书 |
| 19030006 | JS_ERR_KEYUSAGE_NO_CERTSIGN | 密钥用途不含证书签名 |
| 19030007 | JS_ERR_KEYUSAGE_NO_DIGITAL_SIGNATURE | 密钥用途不含数字签名 |
| 19030009 | JS_ERR_CERT_UNTRUSTED | 证书不受信任 |
| 19030010 | JS_ERR_CERT_REVOKED | 证书已被吊销 |
| 19030011 | JS_ERR_CERT_UNKNOWN_CRITICAL_EXTENSION | 证书包含未知关键扩展 |
| 19030012 | JS_ERR_CERT_HOST_NAME_MISMATCH | 主机名不匹配 |
| 19030013 | JS_ERR_CERT_EMAIL_MISMATCH | 邮箱地址不匹配 |
| 19030014 | JS_ERR_CERT_KEY_USAGE_MISMATCH | 密钥用途不匹配 |
| 19030015 | JS_ERR_CRL_NOT_FOUND | CRL未找到 |
| 19030016 | JS_ERR_CRL_NOT_YET_VALID | CRL尚未生效 |
| 19030017 | JS_ERR_CRL_HAS_EXPIRED | CRL已过期 |
| 19030018 | JS_ERR_CRL_SIGNATURE_FAILURE | CRL签名验证失败 |
| 19030019 | JS_ERR_UNABLE_TO_GET_CRL_ISSUER | 无法获取CRL颁发者 |
| 19030020 | JS_ERR_OCSP_RESPONSE_NOT_FOUND | OCSP响应未找到 |
| 19030021 | JS_ERR_OCSP_RESPONSE_INVALID | OCSP响应无效 |
| 19030022 | JS_ERR_OCSP_SIGNATURE_FAILURE | OCSP签名验证失败 |
| 19030023 | JS_ERR_OCSP_VERIFY_FAILED | OCSP验证失败 |
| 19030024 | JS_ERR_OCSP_CERT_STATUS_UNKNOWN | OCSP证书状态未知 |
| 19030025 | JS_ERR_NETWORK_TIMEOUT | 网络超时 |

