### 2.2 Inner C接口

#### 2.2.1 核心数据结构

**验证参数结构体 HcfX509CertValidatorParams**

```c
typedef struct {
    HcfX509CertificateArray untrustedCerts;      // 非信任证书列表
    HcfX509CertificateArray trustedCerts;        // 信任证书列表
    bool trustSystemCa;                          // 是否信任系统CA
    bool partialChain;                           // 是否允许部分链验证
    bool allowDownloadIntermediateCa;            // 是否允许下载中间证书
    bool validateDate;                           // 是否验证日期
    char *date;                                  // 验证日期字符串
    HcfInt32Array ignoreErrs;                    // 忽略的错误码列表
    HcfStringArray hostnames;                    // 主机名列表
    HcfStringArray emailAddresses;               // 邮箱地址列表
    HcfInt32Array keyUsage;                      // 密钥用途列表
    CfBlob userId;                               // 用户ID
    HcfX509CertRevokedParams *revokedParams;     // 吊销检查参数
} HcfX509CertValidatorParams;
```

**吊销检查参数 HcfX509CertRevokedParams**

```c
typedef struct {
    HcfInt32Array revocationFlags;    // 吊销检查标志
    HcfX509CrlArray crls;             // CRL列表
    bool allowDownloadCrl;            // 是否允许下载CRL
    bool allowOcspCheckOnline;        // 是否允许在线OCSP检查
    CfBlobArray ocspResponses;        // OCSP响应数据
    HcfInt32Array ocspDigest;         // OCSP摘要算法
} HcfX509CertRevokedParams;
```

**验证结果结构体 HcfVerifyCertResult**

```c
typedef struct {
    HcfX509CertificateArray certs;    // 验证后的证书链
    const char *errorMsg;             // 错误信息
} HcfVerifyCertResult;
```

**证书链验证器接口 HcfCertChainValidator**

```c
struct HcfCertChainValidator {
    struct CfObjectBase base;

    // 验证证书链（原有接口）
    CfResult (*validate)(HcfCertChainValidator *self, const HcfCertChainData *certChainData);

    // 获取算法名称
    const char *(*getAlgorithm)(HcfCertChainValidator *self);

    // 验证单个X509证书（新增接口）
    CfResult (*validateX509Cert)(HcfCertChainValidator *self, HcfX509Certificate *cert,
        const HcfX509CertValidatorParams *params, HcfVerifyCertResult *result);
};
```

#### 2.2.2 创建函数

```c
/**
 * @brief 创建证书链验证器实例
 * @param algorithm 算法名称，目前支持 "PKIX"
 * @param pathValidator 输出参数，返回验证器实例
 * @return CfResult 操作结果
 */
CfResult HcfCertChainValidatorCreate(const char *algorithm, HcfCertChainValidator **pathValidator);
```

#### 2.2.3 辅助类型定义

**整数数组 HcfInt32Array**

```c
typedef struct {
    int32_t *data;
    uint32_t count;
} HcfInt32Array;
```

**字符串数组 HcfStringArray**

```c
typedef struct {
    char **data;
    uint32_t count;
} HcfStringArray;
```

**证书数组 HcfX509CertificateArray**

```c
typedef struct {
    HcfX509Certificate **data;
    uint32_t count;
} HcfX509CertificateArray;
```

#### 2.2.4 错误码定义 CfResult

```c
typedef enum CfResult {
    CF_SUCCESS = 0,                              // 成功
    CF_INVALID_PARAMS = -10001,                  // 参数无效
    CF_NOT_SUPPORT = -10002,                     // 不支持
    CF_NULL_POINTER = -10003,                    // 空指针
    CF_NOT_EXIST = -10004,                       // 不存在

    CF_ERR_MALLOC = -20001,                      // 内存分配失败
    CF_ERR_COPY = -20002,                        // 内存拷贝失败
    CF_ERR_NAPI = -20003,                        // NAPI调用失败
    CF_ERR_INTERNAL = -20004,                    // 内部错误
    CF_ERR_PARAMETER_CHECK = -20005,             // 参数校验失败

    CF_ERR_CRYPTO_OPERATION = -30001,            // 密码学操作失败
    CF_ERR_CERT_SIGNATURE_FAILURE = -30002,      // 证书签名验证失败
    CF_ERR_CERT_NOT_YET_VALID = -30003,          // 证书尚未生效
    CF_ERR_CERT_HAS_EXPIRED = -30004,            // 证书已过期
    CF_ERR_UNABLE_TO_GET_ISSUER_CERT_LOCALLY = -30005,  // 无法获取本地颁发者证书
    CF_ERR_KEYUSAGE_NO_CERTSIGN = -30006,        // 密钥用途不含证书签名
    CF_ERR_KEYUSAGE_NO_DIGITAL_SIGNATURE = -30007,  // 密钥用途不含数字签名
    CF_ERR_CERT_UNTRUSTED = -30014,              // 证书不受信任
    CF_ERR_CERT_REVOKED = -30015,                // 证书已被吊销
    CF_ERR_CERT_UNKNOWN_CRITICAL_EXTENSION = -30016,  // 未知关键扩展
    CF_ERR_CERT_HOST_NAME_MISMATCH = -30017,     // 主机名不匹配
    CF_ERR_CERT_EMAIL_MISMATCH = -30018,         // 邮箱地址不匹配
    CF_ERR_CERT_KEY_USAGE_MISMATCH = -30019,     // 密钥用途不匹配
    CF_ERR_CRL_NOT_FOUND = -30020,               // CRL未找到
    CF_ERR_CRL_NOT_YET_VALID = -30021,           // CRL尚未生效
    CF_ERR_CRL_HAS_EXPIRED = -30022,             // CRL已过期
    CF_ERR_CRL_SIGNATURE_FAILURE = -30023,       // CRL签名验证失败
    CF_ERR_UNABLE_TO_GET_CRL_ISSUER = -30024,    // 无法获取CRL颁发者
    CF_ERR_OCSP_RESPONSE_NOT_FOUND = -30025,     // OCSP响应未找到
    CF_ERR_OCSP_RESPONSE_INVALID = -30026,       // OCSP响应无效
    CF_ERR_OCSP_SIGNATURE_FAILURE = -30027,      // OCSP签名验证失败
    CF_ERR_OCSP_VERIFY_FAILED = -30028,          // OCSP验证失败
    CF_ERR_OCSP_CERT_STATUS_UNKNOWN = -30029,    // OCSP证书状态未知
    CF_ERR_NETWORK_TIMEOUT = -30030,             // 网络超时
} CfResult;
```

